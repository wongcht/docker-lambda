# Shared library version pins for dockerfiles/Dockerfile and dockerfiles/runtimes/python.
#
# Each NAME=value line is passed into the build as `--build-arg NAME=value`
# (see .github/workflows/ci.yml and scripts/build.sh).
#
# Lines preceded by a `# renovate:` comment are tracked automatically by
# Renovate (see renovate.json). A few libraries have no usable tag-based
# datasource (mismatched tag/version formats, or no tagged mirror) and are
# bumped manually instead.

# renovate: datasource=github-releases depName=Kitware/CMake extractVersion=^v(?<version>.*)$
CMAKE_VERSION=4.3.4

# pkg-config: no tag-based datasource (hosted on freedesktop.org, no tagged mirror) - bump manually
PKGCONFIG_VERSION=0.29.2

# sqlite: hosted on sqlite.org with a custom encoded version number (no tag-based datasource) - bump manually
SQLITE_VERSION=3510200

# libexpat: GitHub tags use underscores (R_2_7_4) vs the dotted version here - bump manually
LIBEXPAT_VERSION=2.7.4

# renovate: datasource=github-tags depName=GNOME/libxml2 extractVersion=^v(?<version>.*)$
LIBXML2_VERSION=2.15.1

# renovate: datasource=github-releases depName=nghttp2/nghttp2 extractVersion=^v(?<version>.*)$
NGHTTP2_VERSION=1.69.0

# curl: GitHub tags use underscores (curl-8_18_0) vs the dotted version here - bump manually
CURL_VERSION=8.20.0

# renovate: datasource=github-tags depName=ebiggers/libdeflate extractVersion=^v(?<version>.*)$
LIBDEFLATE_VERSION=1.25

# renovate: datasource=github-tags depName=pnggroup/libpng extractVersion=^v(?<version>.*)$
LIBPNG_VERSION=1.6.58

# renovate: datasource=github-tags depName=libjpeg-turbo/libjpeg-turbo
LIBJPEG_TURBO_VERSION=3.1.4

# renovate: datasource=github-tags depName=webmproject/libwebp extractVersion=^v(?<version>.*)$
WEBP_VERSION=1.6.0

# renovate: datasource=github-tags depName=facebook/zstd extractVersion=^v(?<version>.*)$
ZSTD_VERSION=1.5.7

# renovate: datasource=github-tags depName=Esri/lerc extractVersion=^v(?<version>.*)$
LERC_VERSION=4.1.0

# renovate: datasource=gitlab-tags depName=libtiff/libtiff extractVersion=^v(?<version>.*)$
LIBTIFF_VERSION=4.7.1

# postgres: GitHub tags use REL_18_2 format vs the dotted version here - bump manually
PG_VERSION=18.4

# renovate: datasource=github-tags depName=uclouvain/openjpeg extractVersion=^v(?<version>.*)$
OPENJPEG_VERSION=2.5.4

# renovate: datasource=github-tags depName=libgeos/geos
GEOS_VERSION=3.14.1

# renovate: datasource=github-tags depName=OSGeo/proj
PROJ_VERSION=9.8.1

# renovate: datasource=github-releases depName=OSGeo/libgeotiff
LIBGEOTIFF_VERSION=1.7.4

# renovate: datasource=github-tags depName=Blosc/c-blosc2 extractVersion=^v(?<version>.*)$
BLOSC2_VERSION=3.1.4

# cryptopp: GitHub tags use underscores (CRYPTOPP_8_9_0) vs the dotted version here - bump manually
CRYPTOPP_VERSION=8.9.0

# szip: no tagged GitHub mirror (hosted on HDF Group's support ftp) - bump manually
SZIP_VERSION=2.1.1

# renovate: datasource=github-tags depName=MathisRosenhauer/libaec extractVersion=^v(?<version>.*)$
LIBAEC_VERSION=1.1.7

# renovate: datasource=github-releases depName=HDFGroup/hdf4 extractVersion=^hdf(?<version>.*)$
HDF4_VERSION=4.3.1

# renovate: datasource=github-tags depName=HDFGroup/hdf5
HDF5_VERSION=2.1.1

# renovate: datasource=github-tags depName=Unidata/netcdf-c extractVersion=^v(?<version>.*)$
NETCDF_VERSION=4.10.0

# renovate: datasource=github-tags depName=google/brotli extractVersion=^v(?<version>.*)$
BROTLI_VERSION=1.2.0

# renovate: datasource=github-tags depName=OSGeo/gdal extractVersion=^v(?<version>.*)$
GDAL_VERSION=3.13.1

# renovate: datasource=github-tags depName=NixOS/patchelf
PATCHELF_VERSION=0.18.0

# Used by dockerfiles/runtimes/python, not dockerfiles/Dockerfile.
# renovate: datasource=pypi depName=numpy
NUMPY_VERSION=2.4.2
