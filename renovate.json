{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "dockerfile": {
    "enabled": false
  },
  "github-actions": {
    "enabled": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Library versions pinned for the lambda-gdal image build",
      "managerFilePatterns": ["/^versions\\.env$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>\\S+))?\\n\\S+_VERSION=(?<currentValue>\\S+)"
      ]
    }
  ]
}
